# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ═══════════════════════════════════════════════════════════════════════════
# PostgreSQL Connection
# ═══════════════════════════════════════════════════════════════════════════
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=SkroutzPR

# ═══════════════════════════════════════════════════════════════════════════
# Gmail Alert on Pipeline Failure (optional)
# Generate an App Password at: myaccount.google.com > Security > App Passwords
# ═══════════════════════════════════════════════════════════════════════════
ALERT_EMAIL=your_gmail@gmail.com
GMAIL_APP_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
# Telegram Bot (optional)
# 1. Message @BotFather on Telegram → /newbot to get a token
# 2. Message @userinfobot to get your chat ID
# ═══════════════════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════════════════════════════
# NVIDIA NIM API (for LLM-powered bot features)
# Get API key at: https://build.nvidia.com (NVIDIA account required)
# Models: nemotron-3-ultra, llama-3.1-70b/8b/405b, codellama-70b, mistral-large, nv-embedqa
# ═══════════════════════════════════════════════════════════════════════════
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# ═══════════════════════════════════════════════════════════════════════════
# Pipeline Settings (optional)
# ═══════════════════════════════════════════════════════════════════════════
# Set to "1" to skip scraping (Stage 1) — used in Docker
SKIP_SCRAPE=0

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Timezone for scheduled tasks
TZ=Europe/Athens