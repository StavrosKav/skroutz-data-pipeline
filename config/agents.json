{
  "scraper_health_monitor": {
    "max_age_hours": 25,
    "min_rows": 10,
    "categories": [
      "phones",
      "laptops",
      "smartwatches",
      "tablets"
    ],
    "folder_map": {
      "phones": "Phones_skroutz",
      "laptops": "Laptops_skroutz",
      "smartwatches": "Smartwatches_skroutz",
      "tablets": "Tablets_skroutz"
    }
  },
  "data_quality": {
    "schema_validator": {
      "_comment": "Schema mirrors the RAW scraper CSV columns (Product, Price_EUR, ...). Price_EUR is a string in raw CSVs (European format, e.g. '1.800.00'); parsing it is the Clean stage's job.",
      "required_fields": [
        "Product",
        "Price_EUR",
        "Link"
      ],
      "schema": {
        "Product": {
          "type": "string",
          "min_length": 1
        },
        "Price_EUR": {
          "type": [
            "string",
            "number"
          ]
        },
        "Link": {
          "type": "string",
          "regex": "^https://www\\.skroutz\\.gr/"
        },
        "Specs": {
          "type": "string"
        },
        "Memory_Info": {
          "type": "string"
        },
        "Rating": {
          "type": "number",
          "min": 0,
          "max": 5
        },
        "Reviews": {
          "type": [
            "number",
            "string"
          ],
          "regex": "^\\d+(\\.\\d+)?\\Z",
          "min": 0
        }
      }
    },
    "anomaly_detector": {
      "method": "iqr",
      "threshold": 1.5,
      "numeric_fields": [
        "Rating",
        "Reviews"
      ],
      "min_samples": 10,
      "anomaly_threshold": 1.0
    },
    "completeness_validator": {
      "critical_fields": [
        "Product",
        "Price_EUR",
        "Link"
      ],
      "warning_fields": [
        "Specs",
        "Rating",
        "Reviews"
      ]
    }
  }
}